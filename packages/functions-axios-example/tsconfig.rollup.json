{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "rootDir": "./src",
    "outDir": "dist",
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/stories/**/*", "**/*.test.ts", "**/*.test.tsx"]
}
