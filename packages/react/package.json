{
  "name": "@jsonui/react",
  "version": "0.10.15",
  "type": "module",
  "author": "Istvan Fodor <fodori@jsonui.org>",
  "contributors": [],
  "bugs": {
    "url": "https://github.com/fodori/jsonui/issues"
  },
  "homepage": "http://www.jsonui.org/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fodori/jsonui.git"
  },
  "description": "Json markup language to define User Interface",
  "keywords": [
    "react",
    "react-component",
    "ui",
    "json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "start": "rollup -c --watch",
    "lint": "eslint src .storybook --max-warnings 0",
    "lint:fix": "eslint src .storybook --fix --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \".storybook/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \".storybook/**/*.ts\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "all": "clear && yarn test && yarn lint && yarn type-check && yarn build"
  },
  "dependencies": {
    "@jsonui/core": "0.10.15"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/react-vite": "^10.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.3.5",
    "jsdom": "^29.0.2",
    "jsonata": "^2.1.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "gitHead": "5401b3d4900ca3032c108d6db00e8a819f4b28e9"
}
