{
  "$comp": "View",
  "style": {
    "padding": 5,
    "paddingTop": 0,
    "fontFamily": "system-ui"
  },
  "$children": [
    {
      "$comp": "Text",
      "$children": "Responsive demo — resize the window to see padding and font size change by breakpoint (base → sm → md → lg).",
      "style": {
        "base": {
          "padding": 8,
          "fontSize": {
            "$modifier": "get",
            "store": "data",
            "path": "/sliderValue"
          },
          "color": "#555",
          "marginBottom": 12
        },
        "sm": {
          "padding": 12,
          "fontSize": {
            "$modifier": "get",
            "store": "data",
            "path": "/sliderValue"
          }
        },
        "md": {
          "padding": 16,
          "fontSize": {
            "$modifier": "get",
            "store": "data",
            "path": "/sliderValue"
          }
        },
        "lg": {
          "padding": 20,
          "fontSize": {
            "$modifier": "get",
            "store": "data",
            "path": "/sliderValue"
          }
        }
      }
    },
    {
      "$comp": "Text",
      "$children": "Responsive demo — resize the window to see padding and font size change by breakpoint (base → sm → md → lg).",
      "style": {
        "padding": 8,
        "fontSize": {
          "$modifier": "get",
          "store": "data",
          "path": "/sliderValue"
        },
        "color": "#555",
        "marginBottom": 12
      }
    },
    {
      "$comp": "FormLayout",
      "style": {
        "display": "flex",
        "flexDirection": "column",
        "gap": 5
      },
      "$childTop": {
        "$comp": "Text",
        "$children": "ChildTop test",
        "style": {
          "fontSize": 16,
          "fontWeight": "bold"
        }
      },
      "$children": [
        {
          "$comp": "Text",
          "$children": "Slider demo",
          "style": {
            "fontSize": 12,
            "color": "#666",
            "marginBottom": 4
          }
        },
        {
          "$comp": "Slider",
          "value": {
            "$modifier": "get",
            "store": "data",
            "path": "/sliderValue"
          },
          "onChange": {
            "$action": "set",
            "store": "data",
            "path": "/sliderValue"
          },
          "min": 0,
          "max": 100,
          "step": 1,
          "style": {
            "width": "100%"
          }
        },
        {
          "$comp": "Text",
          "style": {
            "fontSize": 12,
            "color": "#333",
            "marginBottom": 12
          },
          "$children": {
            "$modifier": "get",
            "store": "data",
            "path": "/sliderValue",
            "jsonataDef": "'Slider value: ' & $"
          }
        },
        {
          "$comp": "Input",
          "value": {
            "$modifier": "get",
            "store": "data",
            "path": "/capitalized",
            "jsonataDef": "($ != null and $ != '') ? $uppercase($) : ''"
          },
          "onChange": {
            "$action": "set",
            "store": "data",
            "path": "/capitalized"
          },
          "placeholder": "Type lowercase...",
          "style": {
            "padding": 8,
            "border": "1px solid #ccc"
          }
        },
        {
          "$comp": "Input",
          "id": "111",
          "value": {
            "$modifier": "get",
            "store": "data",
            "path": "/score"
          },
          "onChange": {
            "$action": "set",
            "store": "data",
            "path": "/score"
          },
          "placeholder": "Just Number allowed",
          "style": {
            "padding": 8,
            "border": "1px solid #ccc"
          }
        },
        {
          "$comp": "Input",
          "store": "data",
          "path": "/simplifiedField",
          "label": "Simplified field",
          "placeholder": "just 0/1 local validation simplified, absolute path",
          "helperText": "Value, onChange, error, fieldTouched are added by the engine.",
          "style": {
            "padding": 8,
            "border": "1px solid #ccc"
          },
          "$validation": [
            {
              "store": "data",
              "path": "/simplifiedField",
              "schema": {
                "type": "string",
                "pattern": "^[0-1]+$",
                "errorMessage": {
                  "pattern": "binary data only"
                }
              }
            }
          ]
        },
        {
          "$comp": "Input",
          "value": {
            "$modifier": "get",
            "store": "data",
            "path": "score2"
          },
          "onChange": {
            "$action": "set",
            "store": "data",
            "path": "score2"
          },
          "$validation": [
            {
              "store": "data",
              "path": "score2",
              "schema": {
                "type": "string",
                "pattern": "^[0-1]+$",
                "errorMessage": {
                  "pattern": "binary data only"
                }
              }
            }
          ],
          "placeholder": "Binary score (0/1 only) relative path",
          "style": {
            "padding": 8,
            "border": "1px solid #ccc"
          }
        },
        {
          "$comp": "Text",
          "$children": {
            "$modifier": "get",
            "store": "data",
            "path": "/score",
            "jsonataDef": "($ != null and $ != '') ? ('Score: ' & $) : 'Enter a score'"
          },
          "style": {
            "color": "#333"
          }
        },
        {
          "$comp": "View",
          "style": {
            "marginTop": 16,
            "border": "1px solid #ddd",
            "padding": 8
          },
          "$children": [
            {
              "$comp": "Text",
              "$children": "Players (editable table)",
              "style": {
                "fontSize": 14,
                "fontWeight": "bold",
                "marginBottom": 8
              }
            },
            {
              "$comp": "View",
              "style": {
                "display": "grid",
                "gridTemplateColumns": "2fr 1fr",
                "gap": 4,
                "fontSize": 12,
                "fontWeight": "bold",
                "borderBottom": "1px solid #ccc",
                "paddingBottom": 4,
                "marginBottom": 4
              },
              "$children": [
                {
                  "$comp": "Text",
                  "$children": "Name"
                },
                {
                  "$comp": "Text",
                  "$children": "Score"
                }
              ]
            },
            {
              "$comp": "View",
              "style": {
                "display": "flex",
                "flexDirection": "column",
                "gap": 4
              },
              "$children": {
                "$isList": true,
                "$listItem": {
                  "$comp": "View",
                  "style": {
                    "display": "grid",
                    "gridTemplateColumns": "2fr 1fr",
                    "gap": 4,
                    "alignItems": "center"
                  },
                  "$children": [
                    {
                      "$comp": "Input",
                      "store": "data",
                      "path": "name",
                      "style": {
                        "padding": 4,
                        "border": "1px solid #ccc",
                        "width": "100%"
                      }
                    },
                    {
                      "$comp": "Input",
                      "store": "data",
                      "path": "score",
                      "style": {
                        "padding": 4,
                        "border": "1px solid #ccc",
                        "width": "100%"
                      }
                    }
                  ]
                },
                "$pathModifiers": {
                  "data": {
                    "path": "/players"
                  }
                }
              }
            }
          ]
        }
      ],
      "$childBottom": {
        "$comp": "SubmitButton",
        "$children": {
          "$modifier": "t",
          "key": "Submit"
        },
        "store": "data",
        "path": "/",
        "style": {
          "padding": 10,
          "background": "#28a745",
          "color": "white",
          "border": "none",
          "borderRadius": 4,
          "cursor": "pointer"
        }
      }
    },
    {
      "$comp": "StoreDebugger",
      "data": {
        "$modifier": "get",
        "store": "data",
        "path": "/"
      },
      "error": {
        "$modifier": "get",
        "store": "data.error",
        "path": "/"
      },
      "touched": {
        "$modifier": "get",
        "store": "data.touch",
        "path": "/"
      }
    }
  ],
  "$validations": [
    {
      "store": "data",
      "path": "/score",
      "schema": {
        "type": "string",
        "pattern": "^[0-9]+$",
        "errorMessage": {
          "pattern": "Score must be a number"
        }
      }
    },
    {
      "store": "data",
      "path": "/players",
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "score": {
              "type": "string",
              "pattern": "^[0-9]+$",
              "errorMessage": {
                "pattern": "Score must be a number"
              }
            }
          },
          "required": ["name", "score"],
          "additionalProperties": true
        }
      }
    }
  ],
  "$translate": {
    "hu": {
      "Submit": "Küldés"
    }
  }
}
