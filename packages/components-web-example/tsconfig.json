{
  "extends": "../../tsconfig",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": ["src/**/*", ".storybook/**/*"],
  "exclude": ["src/stories"]
}
