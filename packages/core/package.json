{
  "name": "@jsonui/core",
  "version": "0.10.0",
  "license": "MIT",
  "homepage": "http://www.jsonui.org/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fodori/jsonui.git"
  },
  "bugs": {
    "url": "https://github.com/fodori/jsonui/issues"
  },
  "description": "JsonUI core: validation, store, JsonUI resolution engine",
  "keywords": [
    "json",
    "jsonui",
    "ui",
    "schema"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "jsonata": "^2.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
