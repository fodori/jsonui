{
  "compilerOptions": {
    "types": [],
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": "src",
    "isolatedModules": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}
