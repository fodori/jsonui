{
  "$comp": "View",
  "style": { "padding": 16, "fontFamily": "system-ui" },
  "$children": [
    {
      "$comp": "Text",
      "$children": "JSONUI AI Version",
      "style": { "fontSize": 24, "fontWeight": "bold", "marginBottom": 16 }
    },
    {
      "$comp": "View",
      "style": {
        "display": "flex",
        "flexDirection": "column",
        "gap": 12,
        "maxWidth": 300
      },
      "$children": [
        {
          "$comp": "Input",
          "value": {
            "$modifier": "get",
            "store": "data",
            "path": "/firstName"
          },
          "onChange": {
            "$action": "set",
            "store": "data",
            "path": "/firstName"
          },
          "placeholder": "First name",
          "style": {
            "padding": 8,
            "border": "1px solid #ccc",
            "borderRadius": 4
          }
        },
        {
          "$comp": "Input",
          "value": { "$modifier": "get", "store": "data", "path": "/lastName" },
          "onChange": {
            "$action": "set",
            "store": "data",
            "path": "/lastName"
          },
          "placeholder": "Last name",
          "style": {
            "padding": 8,
            "border": "1px solid #ccc",
            "borderRadius": 4
          }
        },
        {
          "$comp": "Button",
          "$children": "Submit",
          "onPress": { "$action": "submit" },
          "style": {
            "padding": 10,
            "background": "#007bff",
            "color": "white",
            "border": "none",
            "borderRadius": 4,
            "cursor": "pointer"
          }
        },
        {
          "$comp": "Text",
          "$children": {
            "$modifier": "get",
            "store": "data",
            "path": "/firstName",
            "jsonataDef": "'Hello, ' & ($ ? $ : '...') & '!'"
          },
          "style": { "marginTop": 8, "color": "#333" }
        }
      ]
    }
  ]
}
